# Copy this file to .env and fill in your values
BOT_TOKEN=your_bot_token_here

# Proxy for restricted networks (optional)
# Examples:
#   socks5://127.0.0.1:7890   (Clash)
#   socks5://127.0.0.1:10808  (v2rayN)
#   http://127.0.0.1:7890
PROXY_URL=

# Optional — defaults shown
WARN_LIMIT=3
SPAM_THRESHOLD=5
SPAM_WINDOW_SEC=10
DB_PATH=data/bot.db